# Данные принтера (Настройки -> WLAN на экране принтера, или приложение Bambu Handy)
PRINTER_IP=192.168.1.50
PRINTER_ACCESS_CODE=12345678
PRINTER_SERIAL=01P00A000000000

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# chat_id, куда слать уведомления (свой chat_id можно узнать у @userinfobot)
TELEGRAM_CHAT_ID=123456789

# Как часто опрашивать принтер, секунды
POLL_INTERVAL_SECONDS=5

# Как часто слать статусные уведомления во время печати, секунды
PROGRESS_UPDATE_SECONDS=60

# Язык сообщений бота: ru или en
LOCALE=ru

# Часовой пояс для таймстампов в сообщениях, например Europe/Moscow. По умолчанию UTC
TZ=Europe/Moscow
