# Список принтеров теперь задаётся в printers.yaml (см. printers.example.yaml)

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# chat_id, куда слать уведомления (свой chat_id можно узнать у @userinfobot)
TELEGRAM_CHAT_ID=123456789

# Путь к манифесту принтеров внутри контейнера. По умолчанию в docker-compose.yml
# смонтирована ДИРЕКТОРИЯ ./data как /data (не сам файл!) - это важно: бот
# перезаписывает printers.yaml атомарно (временный файл + rename), а такой
# rename не работает, если в контейнер смонтирован сам файл, а не его
# директория (EBUSY). Если меняете путь - держите его внутри смонтированной
# директории.
PRINTERS_CONFIG=/data/printers.yaml

# Дефолты, если в printers.yaml для конкретного принтера не указано своё значение
DEFAULT_POLL_INTERVAL_SECONDS=5
DEFAULT_PROGRESS_UPDATE_SECONDS=60

# Язык сообщений бота: ru или en
LOCALE=ru

# Часовой пояс для таймстампов в сообщениях, например Europe/Moscow. По умолчанию UTC
TZ=Europe/Moscow

# Форум-топики: один принтер - один топик. Требует, чтобы TELEGRAM_CHAT_ID
# был супергруппой с включёнными темами (Settings -> Topics в клиенте
# Telegram) - конвертация обычной группы в супергруппу происходит на стороне
# Telegram при включении тем и МЕНЯЕТ chat_id, обновите TELEGRAM_CHAT_ID выше
# после этого. По умолчанию выключено (все сообщения в один чат, как раньше).
TELEGRAM_USE_TOPICS=false
